# Database
# Local Postgres — create a database, then point this at it:
DATABASE_URL="postgres://postgres:postgres@localhost:5432/issue_tracker"
# Or use a hosted Postgres such as Neon:
# DATABASE_URL="postgres://user:password@host/dbname?sslmode=require"

# Auth — use a secret at least 32 characters long
JWT_SECRET="replace-with-a-secure-32-char-min-secret"
